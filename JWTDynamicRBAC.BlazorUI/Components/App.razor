<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="stylesheet" href="bootstrap/bootstrap.min.css" />
    <link rel="stylesheet" href="app.css" />
    <link rel="stylesheet" href="JWTDynamicRBAC.BlazorUI.styles.css" />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet @rendermode="new InteractiveServerRenderMode(prerender: false)" />
</head>

<body>
    @* 💡 InteractiveServer ဖြင့် အလုပ်လုပ်ရန် render mode ထည့်ပေးလိုက်ပါ *@
    <Routes @rendermode="new InteractiveServerRenderMode(prerender: false)"/>
    <script src="app.js"></script>
    <script src="_framework/blazor.web.js"></script>

    @* this is authToken in Cookies *@
   <script>

    window.authFunctions = {
        setSecureCookie: function(name, value, expiryInMinutes) {
            let maxAgeSeconds = expiryInMinutes * 60;
            document.cookie = `${name}=${value}; path=/; max-age=${maxAgeSeconds}; SameSite=Lax; Secure`;
        },
        logout: function() {
            document.cookie = "authToken=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;";
        }
    };
</script>
</body>

</html>
