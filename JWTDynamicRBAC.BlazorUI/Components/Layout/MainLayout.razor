@using JWTDynamicRBAC.BlazorUI.Auth
@inject AuthenticationStateProvider AuthStateProvider
@inherits LayoutComponentBase
@inject NavigationManager Nav
@inject HttpClient Http
@inject IJSRuntime JS
<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>

        <div class="top-row px-4">
            <a href="https://learn.microsoft.com/aspnet/core/" target="_blank">About</a>
            <AuthorizeView>
                <Authorized>
                        <button style="border: none; background: none;color:rgb(22, 110, 250);margin-left:30px" @onclick="HandleLogout">Logout</button>
                </Authorized>
                <NotAuthorized>
                    <NavLink class="nav-link" href="/login" Match="NavLinkMatch.All">
                        <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Login
                    </NavLink>
                </NotAuthorized>
            </AuthorizeView>

        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    private async Task HandleLogout()
    {
        // ၁။ API ကို တိုက်ရိုက် ခေါ်ပါ (Backend ဘက်က Token ဖျက်ရန်)
        await Http.PostAsync("api/auth/logout", null);

        // 💡 ၂။ Browser Cookie ထဲက Token (၂) ခုလုံးကို အမြစ်ပြတ် ဖျက်မည့် Code 
        // (မှတ်ချက် - ဖန်တီးစဉ်က ပါဝင်သော SameSite=Lax; Secure; ကို မဖြစ်မနေ ထည့်ပေးထားပါသည်)
        var clearAuthToken = "document.cookie = 'authToken=; path=/; expires=Thu, 01 Jan 1970 00:00:00 UTC; SameSite=Lax; Secure;'; ";
        var clearRefreshToken = "document.cookie = 'refreshToken=; path=/; expires=Thu, 01 Jan 1970 00:00:00 UTC; SameSite=Lax; Secure;'; ";
        
        await JS.InvokeVoidAsync("eval", clearAuthToken + clearRefreshToken);

        // ၃။ Auth State ကို ချက်ချင်း Update လုပ်ရန် Comment ဖြုတ်သုံးသင့်ပါသည်
        if (AuthStateProvider is JWTDynamicRBAC.BlazorUI.Auth.CustomAuthStateProvider customProvider)
        {
            customProvider.NotifyUserLogout();
        }

        // ၄။ Login စာမျက်နှာသို့ အတင်းပြန်ပို့ပါ
        Nav.NavigateTo("/login", forceLoad: true);
    }
}